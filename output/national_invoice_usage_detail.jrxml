<?xml version="1.0" encoding="UTF-8"?>
<!--
  Detail page (subreport)
  Spec: functional_spec/Invoice_Functional_Template.md
  Required parameters: P_TRANS_ID, P_LOGO
  Engine-provided (do not declare): REPORT_CONNECTION via connectionExpression only
  Design assumptions (A1-A15):
  A1: Detail view VW_DOCUMENT_TRANS_DETAIL
  A2: Main filter DETAIL_TYPE='SERVICE' (main report; not applied here)
  A3: Invoice Terms = "Net " + PAYMENT_DUE_DAYS + " days" (main report)
  A4: P_CONTACT_USER optional, default N/A (main report F2)
  A5: Special Deal printWhen when DATA_TYPE VBR or SPECIAL
  A6: DATA_TYPE label mapping (DOMESTIC/INTERNATIONAL/VBR/SPECIAL)
  A7: Calibri font (spec typo Callbri)
  A8: TRAFFIC_PERIOD as-is from view
  A9: Single CURRENCY field
  A10: Origination TBD when null/empty/DUMMY
  A11: Detail filter NET_AMOUNT<>0
  A12: Bank Name=FRN_BANK_NAME (main report F1)
  A13: OPR_CONTACT_NO fallback FRN_TELEPHONE (main report H2)
  A14: pageFooter main only (no pageFooter on this subreport)
  A15: Rate/currency zero uses "\$-" in Groovy textFieldExpression CDATA
  Groups: Invoice Total -> Traffic Period -> Data Type
  Columns: Product Description through Amount (9 columns)
  No pageFooter or summary band on detail subreport
-->
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="national_invoice_usage_detail" language="groovy" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="10d3f4be-7b27-441f-b73d-eec1eae3294d">
