<?xml version="1.0" encoding="UTF-8"?>
<!--
  Cover page (main report / subreport host)
  Spec: functional_spec/Invoice_Functional_Template.md
  Required parameters: P_TRANS_ID, TEMPLATE_FILE_DIRECTORY, P_LOGO
  Optional parameters: P_CONTACT_USER (default "N/A" for F2 Contact No)
  Engine-provided (do not declare): REPORT_CONNECTION, REPORT_LOCALE, etc.
  Design assumptions (A1-A15):
  A1: Detail view VW_DOCUMENT_TRANS_DETAIL (detail subreport query)
  A2: Main filter DETAIL_TYPE='SERVICE'
  A3: Invoice Terms = "Net " + PAYMENT_DUE_DAYS + " days"
  A4: P_CONTACT_USER optional, default N/A
  A5: Special Deal printWhen when DATA_TYPE VBR or SPECIAL
  A6: DATA_TYPE label mapping (DOMESTIC/INTERNATIONAL/VBR/SPECIAL)
  A7: Calibri font (spec typo Callbri)
  A8: TRAFFIC_PERIOD as-is from view
  A9: Single CURRENCY field
  A10: Origination TBD when null/empty/DUMMY (detail subreport)
  A11: Detail filter NET_AMOUNT<>0 (detail subreport)
  A12: Bank Name=FRN_BANK_NAME
  A13: OPR_CONTACT_NO fallback FRN_TELEPHONE
  A14: pageFooter main only
  A15: Currency zero uses "\$-" in Groovy textFieldExpression CDATA
  Groups: Invoice Total -> Traffic Period -> Data Type -> Service Name
  Subreport: national_invoice_usage_detail.jasper (summary band only)
  Spec vs sample: Document labels per spec (Tax Invoice/Outbound Statement)
-->

<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="national_invoice_usage_main" language="groovy" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="13a18aa2-0dc4-4160-b7cb-302b666822b7">
